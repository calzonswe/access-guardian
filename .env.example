# Environment variables for docker-compose
# Copy this file to .env and update the values

# Database
DB_PASSWORD=changeme_in_production

# JWT Secret (used by backend for token signing)
JWT_SECRET=changeme_jwt_secret

# Application port (exposed on host)
APP_PORT=8080

# Frontend API URL (optional, defaults to /api which nginx proxies to backend)
# VITE_API_URL=/api

# Azure AD / Entra ID (OIDC)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
